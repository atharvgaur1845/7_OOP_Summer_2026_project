flowchart TB
    subgraph ENTRY["Entry points"]
        direction LR
        CLI[" cli.Main<br/><small>headless / CI</small>"]
        GUI[" gui.AppLauncher<br/><small>Admin + Participant · MVC/Observer</small>"]
    end

    SVC[" service.AccommodationAllocator<br/><small>validate → solve → fallback → nudge → waitlist</small>"]

    subgraph ALG["algorithm"]
        direction LR
        HUN["HungarianAlgorithm"]
        BIP["BipartiteMatcher"]
        CMB["CostMatrixBuilder<br/><small>ExecutorService</small>"]
    end
    subgraph COST["cost"]
        direction LR
        CS["CostStrategy<br/><small>Strategy + Factory</small>"]
        CFG["AllocationConfig<br/><small>Singleton</small>"]
    end
    subgraph IO["io"]
        direction LR
        REPO["Repository&lt;T&gt;<br/><small>DAO · CSV/JSON</small>"]
        WR["AllocationWriter"]
        ST["AllocationStore<br/><small>serialization</small>"]
    end
    CONC["concurrent.ArrivalStream<br/><small>BlockingQueue · Producer–Consumer</small>"]

    CLI --> SVC
    GUI --> SVC
    GUI -.-> CONC --> SVC
    SVC --> ALG
    SVC --> COST
    SVC --> IO

