flowchart TB
    IN(["Participants  +  Rooms"]):::io
    V["1 · Validate<br/><small>unique IDs, capacity ≥ 0</small>"]:::step
    B["2 · Build cost matrix<br/><small>rooms → beds · soft penalties + hard ∞<br/>parallel · ExecutorService</small>"]:::step
    H["3 · Hungarian solve<br/><small>minimum-cost assignment · O(K³)</small>"]:::core
    F["4 · Bipartite fallback<br/><small>seat stranded-but-feasible participants</small>"]:::step
    R["5 · Roommate nudge<br/><small>cost-neutral co-location</small>"]:::step
    W["6 · Build waitlist<br/><small>PriorityQueue · performers first</small>"]:::step
    OUT(["AllocationResult<br/><small>allocations · waitlist · metrics</small>"]):::io

    IN --> V --> B --> H --> F --> R --> W --> OUT

